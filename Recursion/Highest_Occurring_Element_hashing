class Solution {
public:
    int mostFrequentElement(vector<int>& nums) {
        int maxelle = *max_element(nums.begin(),nums.end());
        vector<int>hash(maxelle+1,0);
        for(int i=0; i<nums.size(); i++){
            hash[nums[i]]+=1;
        }
        int maxfeq=0;
        int answer=-1;
        for(int i=0; i<hash.size(); i++){
            if(hash[i]>maxfeq){
                maxfeq=hash[i];
                answer=i;
            }
        }
        return answer;
    }
};
